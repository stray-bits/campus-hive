generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  MODERATOR
  SUPER_ADMIN
}

enum ReportTargetType {
  POST
  COMMENT
  USER
}

enum ReportStatus {
  PENDING
  OPEN
  REVIEWED
  RESOLVED
  DISMISSED
}

enum ReportReason {
  HARASSMENT
  HATE_SPEECH
  SPAM
  IMPERSONATION
  NSFW
  VIOLENCE
  MISINFORMATION
  ACADEMIC_DISHONESTY
  OTHER
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  password        String
  firstName       String
  lastName        String
  role            UserRole         @default(STUDENT)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  avatarUrl       String?
  bio             String?
  department      String?
  graduationYear  Int?
  username        String?          @unique
  bookmarks       Bookmark[]
  comments        Comment[]
  commentMentions CommentMention[]
  likes           Like[]
  posts           Post[]
  postMentions    PostMention[]

  isSuspended     Boolean  @default(false)
  suspendedAt      DateTime?
  suspensionReason String?
  reportsMade     Report[] @relation("ReportReporter")
  reviewedReports Report[] @relation("ReportReviewedBy")
  reports         Report[] @relation("ReportUser")
}

model Post {
  id                 String        @id @default(cuid())
  content            String?
  authorId           String
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  categoryId         String
  imageUrl           String?
  attachmentName     String?
  attachmentUrl      String?
  videoUrl           String?
  attachmentMimeType String?
  bookmarks          Bookmark[]
  comments           Comment[]
  likes              Like[]
  author             User          @relation(fields: [authorId], references: [id])
  category           Category      @relation(fields: [categoryId], references: [id])
  mentions           PostMention[]

  isAnonymous  Boolean  @default(false)
  isHidden     Boolean  @default(false)
  hiddenAt     DateTime?
  hiddenReason String?
  reports      Report[] @relation("ReportPost")
}

model Comment {
  id           String           @id @default(cuid())
  content      String
  postId       String
  authorId     String
  author       User             @relation(fields: [authorId], references: [id])
  post         Post             @relation(fields: [postId], references: [id])
  mentions     CommentMention[]
  reports      Report[]         @relation("ReportComment")
  isHidden     Boolean          @default(false)
  hiddenAt     DateTime?
  hiddenReason String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime        @updatedAt
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, postId])
}

model Category {
  id    String @id @default(cuid())
  name  String @unique
  posts Post[]
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, postId])
}

model PostMention {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  username  String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model CommentMention {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  username  String
  createdAt DateTime @default(now())
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
}

model Report {
  id           String           @id @default(cuid())
  reporterId   String
  targetType   ReportTargetType
  reason       ReportReason
  details      String?
  status       ReportStatus     @default(PENDING)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  postId       String?
  commentId    String?
  targetUserId String?

  reviewedById   String?
  reviewedAt     DateTime?
  resolutionNote String?
  reporter       User      @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reviewedBy     User?     @relation("ReportReviewedBy", fields: [reviewedById], references: [id])

  post       Post?    @relation("ReportPost", fields: [postId], references: [id], onDelete: Cascade)
  comment    Comment? @relation("ReportComment", fields: [commentId], references: [id], onDelete: Cascade)
  targetUser User?    @relation("ReportUser",fields: [targetUserId], references: [id], onDelete: Cascade)
}
